{
  "name": "telegram-vscode-remote-control",
  "displayName": "Telegram VSCode Remote Control",
  "description": "允许通过Telegram机器人远程控制VS Code的扩展",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "telegram-remote.authenticate",
        "title": "Telegram Remote: Authenticate"
      },
      {
        "command": "telegram-remote.reconnect",
        "title": "Telegram Remote: Reconnect to Bot Server"
      },
      {
        "command": "telegram-remote.disconnect",
        "title": "Telegram Remote: Disconnect from Bot Server"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.5",
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}